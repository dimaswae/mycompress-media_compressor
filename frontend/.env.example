# mycompress — Frontend Environment Variables
# Copy this file to .env (local) or .env.production (GH Pages / Vercel)
# and fill in the values.

# ── Backend API base URL ──────────────────────────────────────────
# The prefix used for all API calls.
# Local dev: leave blank → Vite proxy to http://localhost:8000/api
# Production: set to your deployed backend URL (no trailing slash)
VITE_API_BASE=

# Examples:
#   VITE_API_BASE=https://mycompress.railway.app/api/v1
#   VITE_API_BASE=https://mycompress-api.render.com/api/v1

# ── GitHub Pages base path ────────────────────────────────────────
# Only needed if deploying to GH Pages under a project subdirectory.
# Leave blank for root domain or Vercel.
VITE_GH_PAGES_BASE=

# Examples:
#   VITE_GH_PAGES_BASE=/mycompress-media_compressor/
